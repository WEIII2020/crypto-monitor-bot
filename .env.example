# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Exchange APIs (optional for public data)
BINANCE_API_KEY=optional
BINANCE_API_SECRET=optional

# Database
POSTGRES_USER=cryptobot
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=crypto_monitor
DATABASE_URL=postgresql://cryptobot:change_this_password@postgres:5432/crypto_monitor

# Redis
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@redis:6379/0

# Alert Thresholds
WARNING_THRESHOLD_5M=10.0
CRITICAL_THRESHOLD_5M=20.0
VOLUME_WARNING_MULTIPLIER=5.0
VOLUME_CRITICAL_MULTIPLIER=10.0

# Monitoring Settings
ENABLE_NIGHT_MODE=false
NIGHT_START_HOUR=23
NIGHT_END_HOUR=7

# Logging
LOG_LEVEL=INFO
