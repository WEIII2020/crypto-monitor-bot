# Crypto Monitor Bot - 环境变量配置示例
# 使用方法：复制此文件为 .env 并填写实际值
# cp .env.example .env && vim .env

# ============================================
# Telegram 配置（必需）⭐
# ============================================

# Telegram Bot Token（从 @BotFather 获取）
# 步骤：
#   1. 在 Telegram 搜索 @BotFather
#   2. 发送 /newbot 创建新 Bot
#   3. 按提示设置名称，获取 Token
export TELEGRAM_BOT_TOKEN="your_bot_token_here"

# Telegram Chat ID（接收消息的聊天 ID）
# 获取方法 1：个人 ID
#   1. 搜索 @userinfobot
#   2. 发送任意消息，它会返回你的 ID
# 获取方法 2：群组 ID
#   1. 将 Bot 添加到群组
#   2. 发送消息到群组
#   3. 访问: https://api.telegram.org/bot<YourBOTToken>/getUpdates
export TELEGRAM_CHAT_ID="your_chat_id_here"

# ============================================
# Hermes Agent 配置（可选）
# ============================================

# Hermes Agent 专用 Bot Token（可选）
# 如果不设置，将使用 TELEGRAM_BOT_TOKEN
# 使用场景：希望用不同的 Bot 处理交互命令
# export HERMES_BOT_TOKEN="another_bot_token"

# ============================================
# Binance API 配置（仅交易模式需要）
# ============================================

# Binance API 配置
# 获取方法：
#   1. 登录 Binance 账户
#   2. 个人中心 → API 管理
#   3. 创建 API Key
#   4. 设置权限（读取、交易）
# export BINANCE_API_KEY="your_api_key_here"
# export BINANCE_API_SECRET="your_api_secret_here"

# 使用测试网（默认 false，生产环境设为 false）
# export BINANCE_TESTNET="false"

# ============================================
# 数据库配置（可选）
# ============================================

# PostgreSQL 数据库（用于持久化存储）
export POSTGRES_HOST="localhost"
export POSTGRES_PORT="5432"
export POSTGRES_DB="crypto_monitor"
export POSTGRES_USER="your_username"
export POSTGRES_PASSWORD="your_password"

# Redis 缓存（用于实时数据）
export REDIS_HOST="localhost"
export REDIS_PORT="6379"
export REDIS_PASSWORD=""
export REDIS_DB="0"

# ============================================
# 应用配置
# ============================================

# 运行环境（development, production）
export ENVIRONMENT="production"

# 日志级别（DEBUG, INFO, WARNING, ERROR）
export LOG_LEVEL="INFO"

# 监控币种数量（默认 200）
export MAX_SYMBOLS="200"

# 检查间隔（秒，默认 30）
export CHECK_INTERVAL="30"

# ============================================
# 监控告警配置（可选）
# ============================================

# 健康检查间隔（秒，默认 60）
# export HEALTH_CHECK_INTERVAL="60"

# 资源使用告警阈值
# export MEMORY_THRESHOLD="80"   # 内存使用率 (%)
# export CPU_THRESHOLD="90"      # CPU 使用率 (%)
# export DISK_THRESHOLD="85"     # 磁盘使用率 (%)
# export ERROR_RATE_THRESHOLD="10"  # 错误率（个/5分钟）

# ============================================
# Lana 交易引擎（可选）
# ============================================

# 启用 Lana 集成（true/false）
export LANA_ENABLED="false"
# export LANA_API_KEY=""
# export LANA_API_SECRET=""

# ============================================
# 注意事项
# ============================================

# 1. 最小配置（仅信号监控）：
#    - TELEGRAM_BOT_TOKEN ✅
#    - TELEGRAM_CHAT_ID ✅
#
# 2. 完整配置（交互 + 监控）：
#    - 上述两项 ✅
#    - HERMES_BOT_TOKEN（可选）
#
# 3. 交易模式：
#    - 上述所有项 ✅
#    - BINANCE_API_KEY ✅
#    - BINANCE_API_SECRET ✅
#
# 4. 安全建议：
#    - 设置文件权限: chmod 600 .env
#    - 不要提交到 git: 已在 .gitignore
#    - 定期更换密钥
#
# 5. 测试配置：
#    ./run.sh signal  # 启动测试
